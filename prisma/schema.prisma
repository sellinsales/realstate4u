generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  AGENT
  LANDLORD
  ADMIN
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  OFFICE
  PLOT
  SHOP
  ROOM
}

enum ListingType {
  BUY
  RENT
}

enum PropertyStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum LeadSource {
  WEB
  WHATSAPP
  CALL
}

enum HousingQueueType {
  QUEUE
  FIRSTCOME
  RANDOM
}

enum HousingApplicationStatus {
  PENDING
  SHORTLISTED
  APPROVED
  REJECTED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  role                UserRole             @default(USER)
  emailVerifiedAt     DateTime?
  profile             Profile?
  listings            PropertyListing[]    @relation("PropertyCreator")
  leads               Lead[]
  housingApplications HousingApplication[]
  verificationTokens  EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  phone     String?
  country   String?
  city      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PropertyListing {
  id                  String               @id @default(cuid())
  slug                String               @unique
  title               String
  description         String               @db.Text
  price               Decimal              @db.Decimal(12, 2)
  country             String
  city                String
  address             String?
  latitude            Float?
  longitude           Float?
  propertyType        PropertyType
  listingType         ListingType
  marketCode          String
  locale              String?
  bedrooms            Int?
  bathrooms           Int?
  areaSqm             Int?
  firstHand           Boolean              @default(false)
  landlordSelection   String?
  contactPhone        String?
  whatsappPhone       String?
  createdById         String
  isVerified          Boolean              @default(false)
  status              PropertyStatus       @default(PENDING)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  createdBy           User                 @relation("PropertyCreator", fields: [createdById], references: [id], onDelete: Cascade)
  media               PropertyMedia[]
  leads               Lead[]
  housingQueue        HousingQueue?
  housingApplications HousingApplication[]
}

model PropertyMedia {
  id         String          @id @default(cuid())
  propertyId String
  imageUrl   String
  sortOrder  Int             @default(0)
  property   PropertyListing @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Lead {
  id         String          @id @default(cuid())
  propertyId String
  userId     String?
  name       String
  email      String?
  phone      String?
  message    String          @db.Text
  source     LeadSource      @default(WEB)
  createdAt  DateTime        @default(now())
  property   PropertyListing @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model HousingQueue {
  id              String           @id @default(cuid())
  propertyId      String           @unique
  type            HousingQueueType
  selectionMethod String?
  selectionNotes  String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  property        PropertyListing  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model HousingApplication {
  id         String                   @id @default(cuid())
  propertyId String
  userId     String
  status     HousingApplicationStatus @default(PENDING)
  note       String?                  @db.Text
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  property   PropertyListing          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
